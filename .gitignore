# Secrets
.env

# Database
data/*.db
data/*.sqlite
# ...but DO commit a snapshot so the deployed app (Streamlit Cloud) has data.
!data/market_lens.db
# Never commit SQLite's runtime journal/WAL files (regenerated on each run).
data/*.db-journal
data/*.db-wal
data/*.db-shm

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/

# OS / editor
.DS_Store
.vscode/
.idea/
