# Copy this file to ".env" and fill in your keys.
# The .env file is gitignored — NEVER commit real keys.
# The Week 1 yfinance starter does NOT need any of these; they're for later.

# News (newsapi.org)
NEWSAPI_KEY=

# Financial Modeling Prep (financialmodelingprep.com)
FMP_API_KEY=

# Finnhub (finnhub.io)
FINNHUB_API_KEY=

# FRED macro data (fred.stlouisfed.org)
FRED_API_KEY=

# Reddit sentiment (reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=market-lens by u/yourusername

# SEC EDGAR requires a real contact in the User-Agent header
SEC_USER_AGENT=Market Lens research your.email@example.com
